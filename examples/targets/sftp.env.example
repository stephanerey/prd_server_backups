CONFIG_VERSION="1"
GENERATED_BY="server-backup"
GENERATED_AT="example"

TARGET_NAME="example-sftp"
TARGET_TYPE="sftp"

SSH_HOST_ALIAS="server-backup-example"
SSH_HOSTNAME="backup.example.net"
SSH_PORT="22"
SSH_USER="backup-user"
SSH_IDENTITY_FILE="/etc/server-backup/ssh/id_ed25519_example"
SSH_CONFIG_FILE="/etc/server-backup/ssh/ssh_config"
SSH_KNOWN_HOSTS_FILE="/etc/server-backup/ssh/known_hosts"

RESTIC_REPOSITORY="sftp:server-backup-example:/backups/example-server/restic"
RESTIC_PASSWORD_FILE="/etc/server-backup/secrets/restic-password"
RESTIC_CACHE_DIR="/var/cache/restic"
